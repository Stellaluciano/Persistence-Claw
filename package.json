{
  "name": "persistence-claw",
  "version": "0.1.0",
  "private": true,
  "description": "Neuroscience-inspired visual persistence for OpenClaw that reduces token usage by caching and updating screen perception.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "demo": "pnpm --filter @persistence-claw/demo-desktop-agent demo",
    "benchmark": "pnpm --filter @persistence-claw/benchmark benchmark"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
